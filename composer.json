{
	"name"             : "php-pico/logger",
	"description"      : "PSR-3 compliant logger package.",
	"type"             : "library",
	"license"          : "MIT",
	"minimum-stability": "stable",
	"version"          : "0.1.0",
	"scripts"          : {
		"mago": "mago analyze",
		"test": "phpunit -c phpunit.xml.dist",
		"qa"  : [
			"@mago",
			"@test"
		]
	},
	"require"          : {
		"php"    : "^8.4",
		"psr/log": "^3.0"
	},
	"autoload"         : {
		"psr-4": {
			"PhpPico\\Logger\\": "src/"
		}
	},
	"autoload-dev"     : {
		"psr-4": {
			"PhpPico\\Logger\\Tests\\": "tests/"
		}
	},
	"require-dev"      : {
		"carthage-software/mago": "^1.0.0-rc.12",
		"phpunit/phpunit"       : "^12.5"
	},
	"config"           : {
		"allow-plugins": {
			"carthage-software/mago": true
		}
	}
}
